{
  "name": "ams",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "lucide-react": "^0.546.0",
      "next": "^16.2.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@orpc/server": "^1.13.14",
      "@orpc/client": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.5.5",
      "drizzle-orm": "^0.45.1",
      "pg": "^8.17.1",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev --filter web",
    "db:push": "turbo run db:push --filter @ams/db",
    "db:studio": "turbo run db:studio --filter @ams/db",
    "db:generate": "turbo run db:generate --filter @ams/db",
    "db:migrate": "turbo run db:migrate --filter @ams/db",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@ams/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ams/config": "workspace:*",
    "@biomejs/biome": "2.4.12",
    "@types/node": "^22.13.14",
    "turbo": "^2.9.9",
    "typescript": "catalog:",
    "ultracite": "7.6.2"
  },
  "packageManager": "bun@1.3.13"
}
